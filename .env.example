# Server
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=false

# Database
DB_FILE=data/astra-studio.sqlite

# Admin (IMPORTANT: Change these in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=generate-a-secure-secret-here
ADMIN_SESSION_TTL_HOURS=168

# Student
STUDENT_SESSION_SECRET=generate-a-secure-secret-here
STUDENT_SESSION_TTL_HOURS=720
PASSWORD_RESET_TTL_MINUTES=60
ALLOW_DEV_FAKE_CHECKOUT=true

# SMTP (Email configuration)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
LEADS_NOTIFY_EMAIL=bonjour@astrastudio.fr

# AI (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# Site
SITE_BASE_URL=http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Rate Limiting
LEAD_RATE_LIMIT_MAX=5
LEAD_RATE_LIMIT_WINDOW_MS=3600000

# Directories
ROOT_DIR=
PUBLIC_DIR=public
UPLOADS_DIR=data/uploads
